@page "/documents"
@using DocumentOcr.Common.Interfaces
@using DocumentOcr.Common.Models
@using DocumentOcr.Common.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject ICosmosDbService CosmosDbService
@inject NavigationManager NavigationManager

<PageTitle>Documents</PageTitle>

<h1>Document Review</h1>

<div class="row mb-3">
    <div class="col-md-4">
        <label for="statusFilter" class="form-label">Filter by Status:</label>
        <select id="statusFilter" class="form-select" @onchange="OnStatusFilterChanged">
            <option value="">All Documents</option>
            <option value="Pending">Pending Review</option>
            <option value="Reviewed">Reviewed</option>
        </select>
    </div>
    <div class="col-md-4">
        <label for="checkoutFilter" class="form-label">Checkout state:</label>
        <select id="checkoutFilter" class="form-select" @onchange="OnCheckoutFilterChanged">
            <option value="All">All</option>
            <option value="Free">Free</option>
            <option value="CheckedOut">Checked out</option>
        </select>
    </div>
</div>

@if (isLoading)
{
    <p><em>Loading documents...</em></p>
}
else if (filteredDocuments == null || !filteredDocuments.Any())
{
    <div class="alert alert-info">No documents found.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Document Number</th>
                <th>Identifier</th>
                <th>Original File Name</th>
                <th>Pages</th>
                <th>Fields reviewed</th>
                <th>Status</th>
                <th>Checked out by</th>
                <th>Processed At</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in filteredDocuments)
            {
                <tr>
                    <td>@doc.DocumentNumber</td>
                    <td>@doc.Identifier</td>
                    <td>@doc.OriginalFileName</td>
                    <td>@doc.PageCount</td>
                    <td>@DocumentListFilter.CountFieldsReviewed(doc) / @doc.Schema.Count</td>
                    <td>
                        <span class="badge @GetStatusBadgeClass(doc.ReviewStatus)">
                            @doc.ReviewStatus
                        </span>
                    </td>
                    <td>@(string.IsNullOrEmpty(doc.CheckedOutBy) ? "-" : doc.CheckedOutBy)</td>
                    <td>@doc.ProcessedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    <td>
                        <button class="btn btn-sm btn-primary" @onclick="@(e => ReviewDocument(doc.Id, doc.Identifier))">
                            Review
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<DocumentOcrEntity>? documents;
    private IEnumerable<DocumentOcrEntity>? filteredDocuments;
    private bool isLoading = true;
    private ReviewStatus? selectedStatus;
    private DocumentListFilter.CheckoutFilter selectedCheckout = DocumentListFilter.CheckoutFilter.All;

    protected override async Task OnInitializedAsync()
    {
        await LoadDocuments();
    }

    private async Task LoadDocuments()
    {
        isLoading = true;
        try
        {
            documents = await CosmosDbService.GetDocumentsAsync(reviewStatus: null, maxItems: 100);
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading documents: {ex.Message}");
            documents = new List<DocumentOcrEntity>();
            filteredDocuments = documents;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ApplyFilters()
    {
        if (documents is null) { filteredDocuments = null; return; }
        filteredDocuments = DocumentListFilter.Filter(documents, selectedStatus, selectedCheckout).ToList();
    }

    private void OnStatusFilterChanged(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString();
        selectedStatus = string.IsNullOrEmpty(raw) ? null : Enum.Parse<ReviewStatus>(raw);
        ApplyFilters();
    }

    private void OnCheckoutFilterChanged(ChangeEventArgs e)
    {
        selectedCheckout = Enum.Parse<DocumentListFilter.CheckoutFilter>(e.Value?.ToString() ?? "All");
        ApplyFilters();
    }

    private void ReviewDocument(string id, string identifier)
    {
        NavigationManager.NavigateTo($"/review/{id}/{identifier}");
    }

    private string GetStatusBadgeClass(ReviewStatus status) => status switch
    {
        ReviewStatus.Pending => "bg-warning",
        ReviewStatus.Reviewed => "bg-success",
        _ => "bg-secondary",
    };
}
