@page "/upload"
@using DocumentOcr.Common.Interfaces
@using DocumentOcr.WebApp.Models
@using DocumentOcr.WebApp.Services
@using DocumentOcr.WebApp.Components.Shared
@using Microsoft.AspNetCore.Authorization
@inject IOperationsApiService OperationsApi
@inject IBlobStorageService BlobStorage
@inject NavigationManager Navigation
@inject IConfiguration Configuration
@attribute [Authorize]

<PageTitle>Upload Documents</PageTitle>

<div class="container">
    <div class="row mb-3">
        <div class="col">
            <h1>Upload Documents</h1>
            <p class="text-muted">Upload PDF files to start document extraction (up to 10 files). Optionally restrict
                each file to a page range.</p>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
            </div>
        }

        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Select PDF Files</h5>

                        <div class="mb-3">
                            <label for="fileUpload" class="form-label">Choose PDF files to upload (up to 10)</label>
                            <InputFile id="fileUpload" class="form-control" OnChange="HandleFilesSelected" accept=".pdf"
                                       multiple disabled="@isUploading" />

                            @if (selectedFiles.Count > 1)
                            {
                                <div class="mt-2">
                                    <button type="button" class="btn btn-link btn-sm p-0" @onclick="ApplyRangeToAll"
                                            disabled="@isUploading">
                                        <i class="bi bi-arrow-down-square"></i>
                                        Apply first file's range to all (@selectedFiles.Count files)
                                    </button>
                                </div>
                            }

                            @if (selectedFiles.Any())
                            {
                                <div class="mt-2">
                                    <small class="text-muted">@selectedFiles.Count file(s) selected</small>
                                    <div class="mt-2">
                                        @for (int i = 0; i < selectedFiles.Count; i++)
                                        {
                                            var idx = i;
                                            <PdfRangePicker @key="selectedFiles[idx].File" @ref="pickerRefs[idx]"
                                                            Entry="selectedFiles[idx]" OnEntryChanged="HandleEntryChanged" />
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        @if (BlockedFileNames.Any())
                        {
                            <div class="alert alert-warning py-2">
                                <small>
                                    <i class="bi bi-exclamation-triangle"></i>
                                    Resolve range errors before uploading: @string.Join(", ", BlockedFileNames)
                                </small>
                            </div>
                        }

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary btn-lg" @onclick="UploadFiles"
                                    disabled="@(!CanSubmit || isUploading)">
                                @if (isUploading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Uploading @currentFileIndex of @selectedFiles.Count...</span>
                                }
                                else
                                {
                                    <i class="bi bi-cloud-upload me-2"></i>
                                    <span>Upload and Start Extraction (@selectedFiles.Count file@(selectedFiles.Count != 1 ? "s" : ""))</span>
                                }
                            </button>
                        </div>

                        @if (isUploading)
                        {
                            <div class="progress mt-3" style="height: 25px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar"
                                     style="width: @uploadProgress%" aria-valuenow="@uploadProgress" aria-valuemin="0"
                                     aria-valuemax="100">
                                    @uploadProgress%
                                </div>
                            </div>
                            <div class="text-center mt-2">
                                <small class="text-muted">@uploadStatus</small>
                            </div>
                        }

                        @if (uploadResults.Any())
                        {
                            <div class="mt-3">
                                <h6>Upload Results:</h6>
                                <ul class="list-group">
                                    @foreach (var result in uploadResults)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-start">
                                            <div class="ms-2 me-auto">
                                                <div class="fw-bold">@result.FileName</div>
                                                @if (result.Success)
                                                {
                                                    <small class="text-success">✓ Uploaded successfully - Operation started</small>
                                                }
                                                else
                                                {
                                                    <small class="text-danger">✗ Failed: @result.Error</small>
                                                }
                                            </div>
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card bg-light">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-info-circle"></i> How it works</h5>
                        <ol class="small">
                            <li>Select one or more PDF files (up to 10)</li>
                            <li>Preview each PDF and (optionally) type a page range like <code>3-12, 15</code></li>
                            <li>Click "Upload and Start Extraction"</li>
                            <li>Each file will be uploaded to storage</li>
                            <li>An extraction operation starts for each file (restricted to the chosen pages)</li>
                            <li>You'll be redirected to the Operations page to monitor progress</li>
                        </ol>
                        <hr />
                        <h6>Page-range syntax</h6>
                        <ul class="small mb-0">
                            <li>Blank = all pages</li>
                            <li><code>5</code> = page 5 only</li>
                            <li><code>3-12</code> = pages 3 through 12</li>
                            <li><code>3-12, 15</code> = pages 3-12 and page 15</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

@code {
    private List<UploadFileEntry> selectedFiles = new();
    private List<PdfRangePicker?> pickerRefs = new();
    private bool isUploading = false;
    private string? errorMessage;
    private string? successMessage;
    private int uploadProgress = 0;
    private string uploadStatus = "";
    private int currentFileIndex = 0;
    private List<UploadResult> uploadResults = new();
    private const long MaxFileSize = 50 * 1024 * 1024; // 50 MB
    private const int MaxFileCount = 10;

    private bool CanSubmit => UploadGating.CanSubmit(selectedFiles);

    private IEnumerable<string> BlockedFileNames => UploadGating.BlockedFileNames(selectedFiles);

    private void HandleFilesSelected(InputFileChangeEventArgs e)
    {
        selectedFiles.Clear();
        pickerRefs.Clear();
        uploadResults.Clear();
        errorMessage = null;
        successMessage = null;

        var files = e.GetMultipleFiles(MaxFileCount);
        var rejected = new List<string>();

        foreach (var file in files)
        {
            if (file.Size > MaxFileSize)
            {
                rejected.Add($"{file.Name} (exceeds {FormatFileSize(MaxFileSize)})");
                continue;
            }

            if (!file.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
            {
                rejected.Add($"{file.Name} (not a PDF)");
                continue;
            }

            selectedFiles.Add(new UploadFileEntry { File = file });
            pickerRefs.Add(null);
        }

        if (rejected.Any())
        {
            errorMessage = "Rejected: " + string.Join("; ", rejected);
        }

        if (selectedFiles.Any() && string.IsNullOrEmpty(errorMessage))
        {
            successMessage = $"{selectedFiles.Count} file(s) ready to upload";
        }
    }

    private Task HandleEntryChanged(UploadFileEntry _)
    {
        // FR-015: a corrupt-PDF probe failure surfaces as Entry.RangeError;
        // CanSubmit already excludes it. Just trigger a re-render.
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task ApplyRangeToAll()
    {
        if (selectedFiles.Count < 2) return;
        var expression = selectedFiles[0].RangeExpression;
        for (int i = 1; i < selectedFiles.Count; i++)
        {
            var picker = pickerRefs.ElementAtOrDefault(i);
            if (picker is not null)
            {
                await picker.Set(expression);
            }
            else
            {
                selectedFiles[i].RangeExpression = expression;
            }
        }
        StateHasChanged();
    }

    private async Task UploadFiles()
    {
        if (!CanSubmit)
        {
            errorMessage = "Please resolve all range errors before uploading.";
            return;
        }

        isUploading = true;
        errorMessage = null;
        successMessage = null;
        uploadProgress = 0;
        uploadStatus = "";
        uploadResults.Clear();
        currentFileIndex = 0;

        var containerName = Configuration["Upload:ContainerName"] ?? "uploaded-pdfs";
        var successfulUploads = 0;

        try
        {
            for (int i = 0; i < selectedFiles.Count; i++)
            {
                var entry = selectedFiles[i];
                currentFileIndex = i + 1;

                uploadStatus = $"Uploading file {currentFileIndex} of {selectedFiles.Count}: {entry.File.Name}";
                uploadProgress = (int)((double)i / selectedFiles.Count * 100);
                StateHasChanged();

                try
                {
                    var timestamp = DateTime.UtcNow.ToString("yyyyMMdd-HHmmss");
                    var fileName = Path.GetFileNameWithoutExtension(entry.File.Name);
                    var extension = Path.GetExtension(entry.File.Name);
                    var blobName = $"{timestamp}-{fileName}{extension}";

                    using (var stream = entry.File.OpenReadStream(MaxFileSize))
                    {
                        await BlobStorage.UploadBlobAsync(containerName, blobName, stream, overwrite: false);
                    }

                    var pageRange = string.IsNullOrWhiteSpace(entry.RangeExpression) ? null : entry.RangeExpression;
                    var operation = await OperationsApi.StartOperationAsync(blobName, containerName, pageRange);

                    uploadResults.Add(new UploadResult
                    {
                        FileName = entry.File.Name,
                        Success = true,
                        OperationId = operation.OperationId,
                    });

                    successfulUploads++;
                }
                catch (Exception ex)
                {
                    uploadResults.Add(new UploadResult
                    {
                        FileName = entry.File.Name,
                        Success = false,
                        Error = ex.Message,
                    });
                }
            }

            uploadProgress = 100;
            uploadStatus = $"Complete! Successfully uploaded {successfulUploads} of {selectedFiles.Count} file(s)";
            StateHasChanged();

            if (successfulUploads > 0)
            {
                await Task.Delay(2000);
                Navigation.NavigateTo("/operations");
            }
            else
            {
                errorMessage = "Failed to upload any files. Please check the errors above and try again.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"An unexpected error occurred: {ex.Message}";
            uploadProgress = 0;
            uploadStatus = "";
        }
        finally
        {
            isUploading = false;
        }
    }

    private static string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1) { order++; len /= 1024; }
        return $"{len:0.##} {sizes[order]}";
    }

    private class UploadResult
    {
        public string FileName { get; set; } = string.Empty;
        public bool Success { get; set; }
        public string? OperationId { get; set; }
        public string? Error { get; set; }
    }
}
