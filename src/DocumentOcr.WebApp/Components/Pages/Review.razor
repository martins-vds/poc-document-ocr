@page "/review/{Id}/{Identifier}"
@using DocumentOcr.Common.Interfaces
@using DocumentOcr.Common.Models
@using DocumentOcr.WebApp.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject ICosmosDbService CosmosDbService
@inject IDocumentLockService LockService
@inject IDocumentReviewService ReviewService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthState
@inject IOperationsApiService OperationsApi
@rendermode InteractiveServer

<PageTitle>Review @Identifier</PageTitle>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
    <button class="btn btn-secondary" @onclick="GoBack">Back</button>
}
else if (document is null)
{
    <div class="alert alert-warning">Document not found.</div>
    <button class="btn btn-secondary" @onclick="GoBack">Back</button>
}
else
{
    <div class="review-page">
        <div class="review-header">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <h2 class="mb-1">Review: @document.Identifier</h2>
                    <div class="text-muted small">
                        <strong>@document.OriginalFileName</strong>
                        &nbsp;|&nbsp;@document.PageCount page(s)
                        &nbsp;|&nbsp;Page range: @ReviewUiHelpers.FormatPageRange(operationPageRange)
                        &nbsp;|&nbsp;<span class="badge @StatusBadge(document.ReviewStatus)">@document.ReviewStatus</span>
                    </div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    @if (string.IsNullOrEmpty(document.CheckedOutBy))
                    {
                        <button class="btn btn-primary btn-sm" @onclick="HandleCheckout">Check out for review</button>
                    }
                    else if (CanEdit)
                    {
                        <button class="btn btn-success btn-sm" @onclick="SaveAndCheckIn">Check in</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="CancelCheckout">Cancel checkout</button>
                    }
                    <button class="btn btn-link btn-sm" @onclick="GoBack">Back</button>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(document.CheckedOutBy) && !CanEdit)
            {
                <div class="alert alert-warning py-2 mb-0 mt-2 small">
                    Checked out by <strong>@document.CheckedOutBy</strong>
                    @if (document.CheckedOutAt is not null)
                    {
                        <span> at @document.CheckedOutAt.Value.ToString("yyyy-MM-dd HH:mm")</span>
                    }
                    — read-only.
                </div>
            }

            @if (HasInferredPages)
            {
                <div class="alert alert-warning py-2 mb-0 mt-2 small">
                    <strong>Page-boundary warning:</strong> @InferredPageCount of @document.PageCount pages had their identifier
                    forward-filled. Pages: @string.Join(", ", document.PageProvenance
                                                                                    .Where(p => p.IdentifierSource == IdentifierSource.Inferred)
                                                                                    .Select(p => p.PageNumber.ToString()))
                </div>
            }

            @if (saveStatus is not null)
            {
                <div class="alert @saveAlertClass py-2 mb-0 mt-2 small">@saveStatus</div>
            }
        </div>

        <div class="review-split">
            <div class="review-pdf-pane">
                <iframe name="pdfFrame" src="@PdfUrl" title="PDF preview"></iframe>
            </div>
            <div class="review-form-pane">
                @foreach (var name in ProcessedDocumentSchema.FieldNames)
                {
                    if (!document.Schema.TryGetValue(name, out var field) || field is null) { continue; }
                    var rowClass = ReviewUiHelpers.GetFieldRowCssClass(field);
                    var band = ReviewUiHelpers.GetConfidenceBand(field.OcrConfidence);
                    var bandClass = ReviewUiHelpers.GetConfidenceCssClass(band);
                    var localValue = editValues.TryGetValue(name, out var v) ? v :
            ReviewUiHelpers.GetEditableInitialValue(field);
                    var reviewedDisplay = ReviewUiHelpers.GetReviewedValueDisplay(field);
                    var saving = savingField == name;
                    var fieldName = name;
                    <div class="@rowClass">
                        <div class="field-name">
                            <span>@fieldName</span>
                            <span class="confidence-badge @bandClass">
                                @(field.OcrConfidence?.ToString("P0") ?? "no confidence") · @band
                            </span>
                            <span class="badge @FieldBadge(field.FieldStatus)">@field.FieldStatus</span>
                            @if (PrimaryPage is int pp)
                            {
                                <a class="page-jump-link" href="@ReviewUiHelpers.GetPdfUrl(document.Id, document.Identifier, pp)"
                                   target="pdfFrame">page @pp</a>
                            }
                        </div>
                        @if (field.ReviewedAt is not null)
                        {
                            <div class="field-meta">
                                Reviewed by @field.ReviewedBy at @field.ReviewedAt.Value.ToString("yyyy-MM-dd HH:mm")
                            </div>
                        }
                        <div class="ocr-value">
                            @if (ReviewUiHelpers.IsDateField(fieldName))
                            {
                                var disp = ReviewUiHelpers.GetDateOcrDisplay(field);
                                @(string.IsNullOrEmpty(disp) ? "(none)" : disp)
                            }
                            else
                            {
                                @(field.OcrValue?.ToString() ?? "(none)")
                            }
                        </div>
                        <div class="reviewed-value">@(string.IsNullOrEmpty(reviewedDisplay) ? "no review yet" : reviewedDisplay)
                        </div>
                        @if (CanEdit)
                        {
                            @if (ReviewUiHelpers.IsBooleanField(fieldName))
                            {
                                <select class="form-select form-select-sm mb-2" value="@localValue"
                                        @onchange="e => SetEdit(fieldName, e.Value?.ToString())">
                                    <option value="True">True</option>
                                    <option value="False">False</option>
                                </select>
                            }
                            else if (ReviewUiHelpers.IsDateField(fieldName))
                            {
                                <input type="date" class="form-control form-control-sm mb-2" value="@localValue"
                                       max="@ReviewUiHelpers.TodayIsoUtc()"
                                       @oninput="e => SetEdit(fieldName, e.Value?.ToString())" />
                            }
                            else
                            {
                                <input class="form-control form-control-sm mb-2" value="@localValue"
                                       @oninput="e => SetEdit(fieldName, e.Value?.ToString())" />
                            }
                            <div class="field-actions">
                                <button class="btn btn-sm btn-outline-success" @onclick="() => MarkConfirmed(fieldName)"
                                        disabled="@(saving || (ReviewUiHelpers.IsDateField(fieldName) && field.OcrValue is null))">Confirm</button>
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => MarkCorrected(fieldName)"
                                        disabled="@saving">Correct</button>
                                @if (saving)
                                {
                                    <span class="text-muted small align-self-center">Saving…</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [Parameter] public string Identifier { get; set; } = string.Empty;

    private DocumentOcrEntity? document;
    private string? operationPageRange;
    private string? currentUser;
    private string? errorMessage;
    private bool loading = true;

    private readonly Dictionary<string, string?> editValues = new();
    private string? savingField;
    private string? saveStatus;
    private string saveAlertClass = "alert-success";

    private int? PrimaryPage => ReviewUiHelpers.GetPrimaryPageNumber(document);

    private string PdfUrl =>
        document is null
            ? string.Empty
            : ReviewUiHelpers.GetPdfUrl(document.Id, document.Identifier, PrimaryPage);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            currentUser = auth.User.FindFirst("preferred_username")?.Value
                          ?? auth.User.Identity?.Name;

            document = await CosmosDbService.GetDocumentByIdAsync(Id, Identifier);

            // US3 — fetch the originating operation so the Review metadata
            // can show the page-range used for extraction. Best-effort: if
            // the operation is no longer available we just show "All pages".
            if (!string.IsNullOrEmpty(document?.OperationId))
            {
                try
                {
                    var op = await OperationsApi.GetOperationAsync(document.OperationId);
                    operationPageRange = op?.PageRange;
                }
                catch
                {
                    operationPageRange = null;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private bool CanEdit => document is not null
        && string.Equals(document.CheckedOutBy, currentUser, StringComparison.OrdinalIgnoreCase);

    private bool HasInferredPages =>
        document?.PageProvenance.Any(p => p.IdentifierSource == IdentifierSource.Inferred) ?? false;

    private int InferredPageCount =>
        document?.PageProvenance.Count(p => p.IdentifierSource == IdentifierSource.Inferred) ?? 0;

    private async Task HandleCheckout()
    {
        if (document is null || currentUser is null) return;
        try
        {
            var result = await LockService.TryCheckoutAsync(document.Id, document.Identifier, currentUser);
            if (!result.Acquired)
            {
                Notify($"Already checked out by {result.HeldBy}.", "alert-warning");
            }
            else
            {
                document = result.Document!;
                Notify("Checked out. Edits auto-save per field.", "alert-info");
            }
        }
        catch (Exception ex)
        {
            Notify(ex.Message, "alert-danger");
        }
    }

    private void SetEdit(string field, string? value)
    {
        editValues[field] = value;
    }

    private Task MarkConfirmed(string field) =>
        ApplySingleEdit(field, new FieldEdit(SchemaFieldStatus.Confirmed, null));

    private Task MarkCorrected(string field)
    {
        editValues.TryGetValue(field, out var v);
        return ApplySingleEdit(field, new FieldEdit(SchemaFieldStatus.Corrected, v));
    }

    private async Task ApplySingleEdit(string field, FieldEdit edit)
    {
        if (document is null || currentUser is null) return;
        try
        {
            savingField = field;
            document = await ReviewService.ApplyEditsAsync(
                document.Id, document.Identifier,
                new Dictionary<string, FieldEdit> { [field] = edit },
                currentUser);
            if (document.Schema.TryGetValue(field, out var f))
            {
                editValues[field] = ReviewUiHelpers.GetEditableInitialValue(f);
            }
            Notify($"Saved '{field}'.", "alert-success");
        }
        catch (Exception ex)
        {
            Notify($"Failed to save '{field}': {ex.Message}", "alert-danger");
        }
        finally
        {
            savingField = null;
        }
    }

    private async Task SaveAndCheckIn()
    {
        if (document is null || currentUser is null) return;
        try
        {
            document = await LockService.CheckinAsync(document.Id, document.Identifier, currentUser);
            Notify("Checked in.", "alert-success");
        }
        catch (Exception ex)
        {
            Notify(ex.Message, "alert-danger");
        }
    }

    private async Task CancelCheckout()
    {
        if (document is null || currentUser is null) return;
        try
        {
            document = await LockService.CancelCheckoutAsync(document.Id, document.Identifier, currentUser);
            Notify("Checkout cancelled. Per-field saves retained.", "alert-info");
        }
        catch (Exception ex)
        {
            Notify(ex.Message, "alert-danger");
        }
    }

    private void Notify(string message, string alertClass)
    {
        saveStatus = message;
        saveAlertClass = alertClass;
    }

    private void GoBack() => NavigationManager.NavigateTo("/documents");

    private static string StatusBadge(ReviewStatus status) => status switch
    {
        ReviewStatus.Pending => "bg-warning",
        ReviewStatus.Reviewed => "bg-success",
        _ => "bg-secondary",
    };

    private static string FieldBadge(SchemaFieldStatus status) => status switch
    {
        SchemaFieldStatus.Pending => "bg-warning",
        SchemaFieldStatus.Confirmed => "bg-success",
        SchemaFieldStatus.Corrected => "bg-info",
        _ => "bg-secondary",
    };
}
