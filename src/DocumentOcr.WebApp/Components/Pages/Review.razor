@page "/review/{Id}/{Identifier}"
@using System.Net.Http.Json
@using DocumentOcr.Common.Interfaces
@using DocumentOcr.Common.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject ICosmosDbService CosmosDbService
@inject IDocumentLockService LockService
@inject IDocumentReviewService ReviewService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthState
@rendermode InteractiveServer

<PageTitle>Review @Identifier</PageTitle>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
    <button class="btn btn-secondary" @onclick="GoBack">Back</button>
}
else if (document is null)
{
    <div class="alert alert-warning">Document not found.</div>
    <button class="btn btn-secondary" @onclick="GoBack">Back</button>
}
else
{
    <h1>Review: @document.Identifier</h1>
    <p>
        <strong>Original file:</strong> @document.OriginalFileName
        &nbsp;|&nbsp;<strong>Pages:</strong> @document.PageCount
        &nbsp;|&nbsp;<strong>Status:</strong>
        <span class="badge @StatusBadge(document.ReviewStatus)">@document.ReviewStatus</span>
    </p>

    @if (!string.IsNullOrEmpty(document.CheckedOutBy))
    {
        if (string.Equals(document.CheckedOutBy, currentUser, StringComparison.OrdinalIgnoreCase))
        {
            <div class="alert alert-info">
                You are reviewing this document. Edits are saved per-field.
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                Checked out by <strong>@document.CheckedOutBy</strong>
                @if (document.CheckedOutAt is not null)
                {
                    <span> at @document.CheckedOutAt.Value.ToString("yyyy-MM-dd HH:mm")</span>
                }
                — read-only.
            </div>
        }
    }
    else
    {
        <button class="btn btn-primary mb-3" @onclick="HandleCheckout">Check out for review</button>
    }

    @if (HasInferredPages)
    {
        <div class="alert alert-warning">
            <strong>Page-boundary warning (FR-020):</strong>
            @InferredPageCount of @document.PageCount pages had their identifier
            forward-filled (no <code>fileTkNumber</code> on those pages).
            Verify the identifier is correct for those pages:
            @string.Join(", ", document.PageProvenance
                .Where(p => p.IdentifierSource == IdentifierSource.Inferred)
                .Select(p => p.PageNumber.ToString()))
        </div>
    }

    <table class="table table-striped">
        <thead>
            <tr>
                <th style="width: 22%;">Field</th>
                <th style="width: 28%;">OCR value</th>
                <th style="width: 10%;">Confidence</th>
                <th style="width: 10%;">Status</th>
                <th style="width: 30%;">Reviewed value</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var name in ProcessedDocumentSchema.FieldNames)
            {
                var field = document.Schema.TryGetValue(name, out var f) ? f : null;
                if (field is null) continue;
                var localValue = editValues.TryGetValue(name, out var v) ? v : (field.ReviewedValue?.ToString() ?? field.OcrValue?.ToString() ?? string.Empty);
                <tr>
                    <td>@name</td>
                    <td><code>@(field.OcrValue?.ToString() ?? "(none)")</code></td>
                    <td>@(field.OcrConfidence?.ToString("0.00") ?? "-")</td>
                    <td>
                        <span class="badge @FieldBadge(field.FieldStatus)">@field.FieldStatus</span>
                    </td>
                    <td>
                        @if (CanEdit)
                        {
                            <input class="form-control form-control-sm" value="@localValue"
                                   @oninput="e => SetEdit(name, e.Value?.ToString())" />
                            <div class="btn-group mt-1" role="group">
                                <button class="btn btn-sm btn-outline-success" @onclick="() => MarkFieldConfirmed(name)">Confirm</button>
                                <button class="btn btn-sm btn-outline-warning" @onclick="() => MarkFieldCorrected(name)">Correct</button>
                            </div>
                        }
                        else
                        {
                            <span>@localValue</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (CanEdit)
    {
        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-success" @onclick="SaveAndCheckIn">Save & Check In</button>
            <button class="btn btn-secondary" @onclick="CancelCheckout">Cancel checkout</button>
            <button class="btn btn-link" @onclick="GoBack">Back</button>
        </div>
    }
    else
    {
        <button class="btn btn-link mt-3" @onclick="GoBack">Back</button>
    }

    @if (saveStatus is not null)
    {
        <div class="alert @saveAlertClass mt-3">@saveStatus</div>
    }
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;
    [Parameter] public string Identifier { get; set; } = string.Empty;

    private DocumentOcrEntity? document;
    private string? currentUser;
    private string? errorMessage;
    private bool loading = true;

    private readonly Dictionary<string, string?> editValues = new();
    private readonly Dictionary<string, FieldEdit> pendingEdits = new();
    private string? saveStatus;
    private string saveAlertClass = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthState.GetAuthenticationStateAsync();
            currentUser = auth.User.FindFirst("preferred_username")?.Value
                          ?? auth.User.Identity?.Name;

            document = await CosmosDbService.GetDocumentByIdAsync(Id, Identifier);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private bool CanEdit => document is not null
        && string.Equals(document.CheckedOutBy, currentUser, StringComparison.OrdinalIgnoreCase);

    private bool HasInferredPages =>
        document?.PageProvenance.Any(p => p.IdentifierSource == IdentifierSource.Inferred) ?? false;

    private int InferredPageCount =>
        document?.PageProvenance.Count(p => p.IdentifierSource == IdentifierSource.Inferred) ?? 0;

    private async Task HandleCheckout()
    {
        if (document is null || currentUser is null) return;
        try
        {
            var result = await LockService.TryCheckoutAsync(document.Id, document.Identifier, currentUser);
            if (!result.Acquired)
            {
                saveStatus = $"Already checked out by {result.HeldBy}.";
                saveAlertClass = "alert-warning";
            }
            else
            {
                document = result.Document!;
            }
        }
        catch (Exception ex)
        {
            saveStatus = ex.Message;
            saveAlertClass = "alert-danger";
        }
    }

    private void SetEdit(string field, string? value)
    {
        editValues[field] = value;
    }

    private void MarkFieldConfirmed(string field)
    {
        pendingEdits[field] = new FieldEdit(SchemaFieldStatus.Confirmed, null);
    }

    private void MarkFieldCorrected(string field)
    {
        editValues.TryGetValue(field, out var v);
        pendingEdits[field] = new FieldEdit(SchemaFieldStatus.Corrected, v);
    }

    private async Task SaveAndCheckIn()
    {
        if (document is null || currentUser is null) return;
        try
        {
            if (pendingEdits.Count > 0)
            {
                document = await ReviewService.ApplyEditsAsync(document.Id, document.Identifier, pendingEdits, currentUser);
                pendingEdits.Clear();
            }
            document = await LockService.CheckinAsync(document.Id, document.Identifier, currentUser);
            saveStatus = "Saved and checked in.";
            saveAlertClass = "alert-success";
        }
        catch (Exception ex)
        {
            saveStatus = ex.Message;
            saveAlertClass = "alert-danger";
        }
    }

    private async Task CancelCheckout()
    {
        if (document is null || currentUser is null) return;
        try
        {
            document = await LockService.CancelCheckoutAsync(document.Id, document.Identifier, currentUser);
            pendingEdits.Clear();
            saveStatus = "Checkout cancelled. Saved per-field edits retained.";
            saveAlertClass = "alert-info";
        }
        catch (Exception ex)
        {
            saveStatus = ex.Message;
            saveAlertClass = "alert-danger";
        }
    }

    private void GoBack() => NavigationManager.NavigateTo("/documents");

    private static string StatusBadge(ReviewStatus status) => status switch
    {
        ReviewStatus.Pending => "bg-warning",
        ReviewStatus.Reviewed => "bg-success",
        _ => "bg-secondary",
    };

    private static string FieldBadge(SchemaFieldStatus status) => status switch
    {
        SchemaFieldStatus.Pending => "bg-warning",
        SchemaFieldStatus.Confirmed => "bg-success",
        SchemaFieldStatus.Corrected => "bg-info",
        _ => "bg-secondary",
    };
}
